            </head>
            <body style=\"font-size:%3$s; %5$s\">
                <p style=\"white-space: pre-wrap;\"><span style=\"color:blue;\">%1$s</span><hr/>%2$s</p>
            </body>
        </html>
    ]]>
    </string>
