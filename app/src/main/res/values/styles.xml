<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="subtitle">
        <item name="android:background">#BBBBBB</item>
        <item name="android:textColor">#EEEEEE</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">@dimen/subtitle_text_size</item>
        <item name="android:lines">2</item>
    </style>

    <style name="CustomTheme" parent="@style/Theme.AppCompat.Light">
        <item name="android:windowTranslucentNavigation">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">false</item>
    </style>

    <style name="CustomTheme.NoActionBar" parent="@style/Theme.AppCompat.Light.NoActionBar">
        <item name="android:windowTranslucentNavigation">false</item>
        <item name="android:windowDrawsSystemBarBackgrounds">false</item>
    </style>

</resources>