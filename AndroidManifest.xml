<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
          xmlns:tools="http://schemas.android.com/tools"
          android:versionName="2.3.9"
          android:versionCode="02309"
          android:installLocation="auto"
          package="com.watnapp.etipitaka.plus">

    <uses-sdk android:minSdkVersion="14" android:targetSdkVersion="22"/>
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"/>
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <application
            android:allowBackup="true"
            android:icon="@drawable/icon"
            android:label="@string/app_name"
            android:theme="@style/Theme.Sherlock.Light"
            android:name=".E_TipitakaApplication">

        <uses-library android:required="false" android:name="com.sec.android.app.multiwindow" />

        <meta-data android:name="com.sec.android.support.multiwindow" android:value="true" />
        <meta-data android:name="com.sec.android.multiwindow.DEFAULT_SIZE_W" android:value="632.0dip" />
        <meta-data android:name="com.sec.android.multiwindow.DEFAULT_SIZE_H" android:value="598.0dip" />
        <meta-data android:name="com.sec.android.multiwindow.MINIMUM_SIZE_W" android:value="632.0dip" />
        <meta-data android:name="com.sec.android.multiwindow.MINIMUM_SIZE_H" android:value="598.0dip" />

        <activity
                android:name=".activity.StartupActivity"
                android:configChanges="orientation|keyboardHidden|screenLayout|touchscreen|screenSize"
                android:theme="@style/Theme.Sherlock.Light.NoActionBar"
                android:label="E-Tipitaka+">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
                <category android:name="android.intent.category.MULTIWINDOW_LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
                android:name=".activity.MainActivity"
                android:theme="@style/Theme.Sherlock.Light"
                android:configChanges="orientation|keyboardHidden|screenLayout|touchscreen|screenSize"
                android:label="E-Tipitaka"
                android:uiOptions="splitActionBarWhenNarrow">
        </activity>
        <activity
                android:name=".activity.ComparisonActivity"
                android:screenOrientation="landscape"
                android:theme="@style/Theme.Sherlock.Light.NoActionBar">
        </activity>
        <activity
                android:name=".activity.FileExplorerActivity"
                android:configChanges="orientation|keyboardHidden|screenLayout|touchscreen|screenSize"
                android:windowSoftInputMode="stateHidden"
                android:theme="@style/Theme.Sherlock.Light.NoActionBar">
        </activity>
        <activity
                android:name=".activity.PaliDictActivity"
                android:configChanges="orientation|keyboardHidden|screenLayout|touchscreen|screenSize"
                android:theme="@style/Theme.Sherlock.Light"
                android:label="@string/pali_dict">
        </activity>
        <activity
                android:name=".activity.ThaiDictActivity"
                android:configChanges="orientation|keyboardHidden|screenLayout|touchscreen|screenSize"
                android:theme="@style/Theme.Sherlock.Light"
                android:label="@string/thai_dict">
        </activity>
        <activity
                android:name=".activity.EnglishDictActivity"
                android:configChanges="orientation|keyboardHidden|screenLayout|touchscreen|screenSize"
                android:theme="@style/Theme.Sherlock.Light"
                android:label="@string/english_dict">
        </activity>

        <provider
                android:name=".model.DatabaseProvider"
                android:authorities="com.watnapp.etipitaka.plus.model.contentprovider"
                android:enabled="true"
                tools:ignore="ExportedContentProvider" >
        </provider>

    </application>
</manifest>
